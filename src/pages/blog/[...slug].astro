---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={`${SITE_URL}/blog/${post.slug}/`}
>
  <Header />

  <article class="blog-post">
    <header class="blog-post-header">
      <div class="blog-card-tags" style="margin-bottom: 16px;">
        {post.data.tags.map((tag) => (
          <a href="/blog/" class="tag">{tag}</a>
        ))}
      </div>
      <h1>{post.data.title}</h1>
      <div class="blog-post-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>

    <div class="blog-post-content">
      <Content />
    </div>

    <div style="margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--border);">
      <a href="/blog/" style="font-size: 0.9375rem; font-weight: 500;">
        &larr; Back to all posts
      </a>
    </div>
  </article>

  <Footer />
</BaseLayout>
