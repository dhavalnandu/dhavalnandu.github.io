---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LINKEDIN_URL } from '../consts';
---

<BaseLayout title="Home" description="Dhaval Nandu - Senior SAP Technical Consultant | ABAP | S/4HANA | RAP | CDS | AMDP">

  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <img src="/dhaval-nandu.jpg" alt="Dhaval Nandu" class="hero-photo" />
        <div class="hero-text">
          <h1>Dhaval <span class="hero-title-accent">Nandu</span></h1>
          <p class="hero-subtitle">
            Senior SAP Technical Consultant with 12+ years delivering enterprise-grade solutions across SAP ECC and S/4HANA. 
            Specializing in RAP, CDS, AMDP, and performance optimization.
          </p>
          <div class="btn-group">
            <a href="#" class="btn btn-white" onclick="document.getElementById('resumeModal').style.display='flex';return false;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              View Resume
            </a>
            <a href={LINKEDIN_URL} class="btn btn-outline" style="color:#fff;border-color:rgba(255,255,255,.3);" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              Connect on LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section-title">Professional Summary</h2>
      <p style="color: var(--text-muted); line-height: 1.8; margin-bottom: 48px; font-size: 1.0625rem;">
        Senior SAP Technical Consultant with over 12 years of hands-on experience across SAP ECC and S/4HANA environments. 
        Proven track record in leading complex delivery programs, performing code remediation during upgrades, 
        and building modern ABAP artifacts using RAP, CDS, and AMDP. Deep expertise in performance optimization 
        through HANA pushdown techniques and a strong focus on clean, maintainable code.
      </p>

      <h2 class="section-title">Key Expertise</h2>
      <p class="section-subtitle">Technologies and domains I work with daily.</p>
      <div class="expertise-grid">
        <div class="expertise-card">
          <h3>Core ABAP &amp; OO ABAP</h3>
          <p>Reports, ALV, Smart Forms, Adobe Forms, BAPIs, BAdIs, User Exits, Enhancement Framework, Module Pool, Dialog Programming</p>
        </div>
        <div class="expertise-card">
          <h3>RAP &amp; CDS</h3>
          <p>RESTful ABAP Programming Model, managed/unmanaged scenarios, behavior definitions, projection views, metadata extensions</p>
        </div>
        <div class="expertise-card">
          <h3>AMDP &amp; HANA Pushdown</h3>
          <p>ABAP Managed Database Procedures, CDS table functions, SQLScript, code-to-data paradigm, performance tuning</p>
        </div>
        <div class="expertise-card">
          <h3>S/4HANA Upgrades</h3>
          <p>Custom code remediation, ATC checks, SPDD/SPAU, data model adaptation, simplification item resolution</p>
        </div>
        <div class="expertise-card">
          <h3>Integrations</h3>
          <p>OData services (SEGW, RAP), IDocs, RFCs, SOAP/REST proxies, PI/PO, CPI, EDI</p>
        </div>
        <div class="expertise-card">
          <h3>Agile &amp; Leadership</h3>
          <p>Scrum/Agile delivery, code reviews, technical design, mentoring, stakeholder management, estimation</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2 class="section-title">Major Programs</h2>
      <p class="section-subtitle">Select engagements that demonstrate breadth and depth.</p>
      <div class="timeline">
        <div class="timeline-item">
          <span class="timeline-date">Recent</span>
          <h3 class="timeline-title">International Supply Chain Platform (INTLSCP)</h3>
          <p class="timeline-company">Team Lead</p>
          <div class="timeline-desc">
            <ul>
              <li>Led technical delivery for a global supply chain management platform</li>
              <li>Designed and implemented RAP-based OData services for real-time inventory tracking</li>
              <li>Built CDS views with complex joins, aggregations, and annotations</li>
              <li>Coordinated a cross-functional team across multiple geographies</li>
              <li>Conducted code reviews and ensured adherence to ABAP clean code standards</li>
            </ul>
          </div>
        </div>
        <div class="timeline-item">
          <span class="timeline-date">Recent</span>
          <h3 class="timeline-title">S/4HANA Upgrade Program</h3>
          <p class="timeline-company">Senior Technical Consultant</p>
          <div class="timeline-desc">
            <ul>
              <li>Performed code remediation for 500+ custom Z-objects using ATC and custom checks</li>
              <li>Developed new CDS views and RAP artifacts aligned with S/4HANA data models</li>
              <li>Resolved SPDD/SPAU dictionary and repository conflicts</li>
              <li>Migrated classical ABAP reports to modern CDS + AMDP patterns</li>
              <li>Reduced report execution time by 60% through HANA pushdown optimization</li>
            </ul>
          </div>
        </div>
        <div class="timeline-item">
          <span class="timeline-date">Previous</span>
          <h3 class="timeline-title">Unicode Migration &amp; ECC Upgrade</h3>
          <p class="timeline-company">Technical Consultant</p>
          <div class="timeline-desc">
            <ul>
              <li>Executed Unicode conversion and ECC version upgrade with zero data loss</li>
              <li>Fixed syntax errors, character encoding issues, and interface incompatibilities</li>
              <li>Validated and corrected custom code for Unicode compliance</li>
            </ul>
          </div>
        </div>
        <div class="timeline-item">
          <span class="timeline-date">Previous</span>
          <h3 class="timeline-title">HR WebDynpro Application</h3>
          <p class="timeline-company">Technical Lead</p>
          <div class="timeline-desc">
            <ul>
              <li>Developed WebDynpro ABAP applications for HR employee self-service</li>
              <li>Integrated with SAP DMS for document attachment and retrieval</li>
              <li>Built complex BAPI integrations for personnel actions</li>
            </ul>
          </div>
        </div>
        <div class="timeline-item">
          <span class="timeline-date">Previous</span>
          <h3 class="timeline-title">OData-based HR Fiori Apps</h3>
          <p class="timeline-company">Technical Consultant</p>
          <div class="timeline-desc">
            <ul>
              <li>Designed and published OData services for SAP Fiori HR applications</li>
              <li>Implemented CRUD operations with proper error handling and authorization</li>
              <li>Optimized service response times through selective data fetching</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
